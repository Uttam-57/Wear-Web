{
  "name": "server",
  "version": "1.0.0",
  "description": "Project Server",
  "license": "ISC",
  "author": "uttam santoki",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "cross-env NODE_ENV=production node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed_data/index.js",
    "seed:keep": "node src/seed_data/index.js --keep-existing",
    "seed:categories": "node src/seed_data/implemented/runCategories.js",
    "seed:categories:keep": "node src/seed_data/implemented/runCategories.js --keep-existing",
    "seed:products": "node src/seed_data/implemented/runProducts.js",
    "seed:products:keep": "node src/seed_data/implemented/runProducts.js --keep-existing",
    "seed:orders": "node src/seed_data/implemented/runOrders.js",
    "seed:orders:keep": "node src/seed_data/implemented/runOrders.js --keep-existing",
    "seed:reviews": "node src/seed_data/implemented/runReviews.js",
    "seed:reviews:keep": "node src/seed_data/implemented/runReviews.js --keep-existing",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dns2": "^2.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "nodemon": "^3.1.14",
    "slugify": "^1.6.6",
    "stripe": "^21.0.1",
    "twilio": "^5.12.2",
    "updates": "^17.8.3",
    "winston": "^3.19.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2"
  }
}
